{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "limitless-organizer-tracker (backend)",
  "dockerComposeFile": ["../docker-compose.yml", "../docker-compose.override.yml"],
  "service": "backend",
  "workspaceFolder": "/workspace",
  "shutdownAction": "none",
  "forwardPorts": [8000, 5173, 5432, 6379],
  "portsAttributes": {
    "8000": { "label": "backend (FastAPI)" },
    "5173": { "label": "frontend (Vite)" },
    "5432": { "label": "postgres" },
    "6379": { "label": "redis" }
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "pip install -e '/app[dev]'",
  "mounts": [
    "source=${localEnv:HOME}/.claude/projects/-Users-bkcrisler-Documents-GitHub-limitless-organizer-tracker/memory,target=/root/.claude/projects/-workspace/memory,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "eamodio.gitlens",
        "usernamehw.errorlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.testing.pytestEnabled": true,
        "python.testing.cwd": "/workspace/backend",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        }
      }
    }
  }
}
