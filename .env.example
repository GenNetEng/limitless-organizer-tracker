# Copy this file to .env and fill in real values. .env is gitignored.

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/limitless_tracker

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Limitless TCG (password login) ---
LIMITLESS_BASE_URL=https://play.limitlesstcg.com
LIMITLESS_USERNAME=
LIMITLESS_PASSWORD=

# --- Discord ---
DISCORD_WEBHOOK_URL=

# --- CORS ---
# Comma-separated list of origins allowed to call the API (the frontend dev
# server / docker-compose frontend container).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Scheduling (UTC) ---
# How often to check the organizer-application status, in hours.
APPLICATION_STATUS_CHECK_INTERVAL_HOURS=4
# Daily resubmission times, 24h "HH:MM" UTC. Provide 1 or 2.
RESUBMIT_TIMES_UTC=09:00,21:00
# How often to ingest tournament data, in hours.
TOURNAMENT_INGEST_INTERVAL_HOURS=1
# Number of most-recent tournaments to pull per ingestion run.
TOURNAMENT_INGEST_LIMIT=1000

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
